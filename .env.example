# Text2Reel Environment Variables

# SQLite Database (Prisma)
DATABASE_URL="file:./prisma/text2reel.db"

# Groq API Key for AI scene generation
# Get yours at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Asset Library APIs (Required for Cloud Search)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_APPLICATION_ID=your_unsplash_application_id_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here


